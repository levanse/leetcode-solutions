{
  "env": {
    "node": true,
    "commonjs": true,
    "es2021": true
  },
  "extends": "next/core-web-vitals",
  "parserOptions": {
    "ecmaVersion": 2022
  },
  "plugins": ["@typescript-eslint"],
  "rules": {
    "semi": ["error", "always"],
    "@typescript-eslint/no-unused-vars": ["warn"],
    "no-unexpected-multiline": 1,
    "no-useless-escape": 1,
    "@next/next/no-img-element": "off"
  }
}
